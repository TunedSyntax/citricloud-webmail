PORT=8080
MAIL_TLS_REJECT_UNAUTHORIZED=false
PUBLIC_WEBMAIL_URL=https://<your-webmail-hostname>
SESSION_STORAGE=encrypted-file
SESSION_ENCRYPTION_KEY=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=86400
SESSION_FILE_PATH=./data/sessions.enc.json
REDIS_URL=redis://:replace-with-redis-password@localhost:6379
SESSION_REDIS_PREFIX=citricloud:webmail:session:

# Mail connection presets (required) — JSON array of MailConnectionPreset objects.
# Copy this file to .env and fill in real values. Never commit .env.
MAIL_PRESETS_JSON=[{"key":"EXTERNAL","label":"External Mail","environment":"Prod","domainSuffix":"<mail-domain>","imap":{"host":"<imap-host>","port":993,"secure":true},"smtp":{"host":"<smtp-host>","port":587,"secure":false}}]