PORT=8080
MAIL_TLS_REJECT_UNAUTHORIZED=false
PUBLIC_WEBMAIL_URL=https://webmail.citricloud.com
SESSION_STORAGE=encrypted-file
SESSION_ENCRYPTION_KEY=replace-with-a-long-random-secret
SESSION_TTL_SECONDS=86400
SESSION_FILE_PATH=./data/sessions.enc.json
REDIS_URL=redis://:replace-with-redis-password@localhost:6379
SESSION_REDIS_PREFIX=citricloud:webmail:session:
# Comma-separated list of email domains that are allowed to log in.
# When left empty, all domains are permitted (open / development mode).
# Example: ALLOWED_DOMAINS=citricloud.com,subdomain.citricloud.com
ALLOWED_DOMAINS=
# Comma-separated list of email domains whose users receive the "admin" role.
# Admin users can perform destructive operations such as deleting messages.
# All other authenticated users receive the "user" role.
# Example: ADMIN_DOMAINS=admin.citricloud.com
ADMIN_DOMAINS=